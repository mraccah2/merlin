data/memory-db-snapshots/

# Wiki access log (runtime state — feeds the nightly pin auditor)
data/wiki-access.jsonl

# Runtime state — append-only or frequently-mutated files written by running
# processes on the mac mini. Tracking these in git means any `git reset
# --hard`, `git checkout .`, or force-push-and-reset sequence wipes live
# data back to whenever the file was last committed. 2026-04-16 incident:
# a reset-after-force-push wiped today's 5 hum tick traces and bounced
# hum-state.json back to 2026-04-14, causing hum-daily to report an empty
# day. These files must live on the mac mini's filesystem only.
#
# Hum runtime:
data/hum-feedback.jsonl
data/hum-interests-state.json
data/hum-learnings.jsonl
data/hum-runs.jsonl
data/memory-retrieval.jsonl
data/outbound-precheck-log.jsonl
data/hum-seen.json
data/hum-state.json
data/hum-ideas.jsonl
data/hum-pending-question.json
data/hum-cache/
data/.cache/
# Supervisor session state (turn count, cost, session id — mutated every turn):
agent/supervisor/state/chat/session.json
agent/supervisor/state/ops/session.json
# Email pipeline (append-only or cursor-style):
data/email-inbound-dropped.jsonl
data/email-inbound-handled.jsonl
data/merlin-sent-mail.jsonl
data/last-history-id.json
# Phone channel cursors + counters:
data/last-merlin-message-at.json
data/phone-channel-cursor.json
data/phone-channel-haiku-counter.json
# Location enrichment queue (mutated as visits close):
data/location-pending-enrich.json
# Location edge-detection dedup (written every tick by merlin CLI):
data/location-edge-seen.json
# Hum ideation scorecard (mutated per run):
data/hum-ideas-scorecard.json
# Hum watchlist approval pointer (4h TTL, written per discover run):
data/hum-pending-approval.json
# Concert watcher dedup state (written every run):
data/concert-watcher-seen.json
