  if (!fs.existsSync(EMAIL_MEM_BIN)) die('email-mem not found at ' + EMAIL_MEM_BIN);
  // pass through to email-mem
  try {
    execFileSync(EMAIL_MEM_BIN, args, { stdio: 'inherit' });
  } catch (e) { process.exit(e.status || 1); }
}

function cmdTriageSpam(args) {
  if (!fs.existsSync(SPAM_FILTER_BIN)) die('spam-filter not found at ' + SPAM_FILTER_BIN);
  try {
    execFileSync(SPAM_FILTER_BIN, args, { stdio: 'inherit' });
  } catch (e) { process.exit(e.status || 1); }
}

function cmdTriagePause() {
  if (fs.existsSync(PAUSE_FLAG)) { console.log(c.yellow('already paused')); return; }
  fs.writeFileSync(PAUSE_FLAG, new Date().toISOString() + '\n');
  console.log(c.yellow('⏸ triage paused'));
  console.log(c.dim('  gmail-channel will drop notifications (historyId still saved).'));
  console.log(c.dim('  Note: takes effect immediately for NEW gmail-channel events.'));
  console.log(c.dim('  Use `merlin triage resume` to re-enable.'));
}

function cmdTriageResume() {
  if (!fs.existsSync(PAUSE_FLAG)) { console.log(c.dim('not paused')); return; }
  const since = fs.readFileSync(PAUSE_FLAG, 'utf8').trim();
  fs.unlinkSync(PAUSE_FLAG);
  console.log(c.green('▶ triage resumed') + c.dim(` (was paused since ${since})`));
  // Dispatch CATCH UP task so ops-agent processes emails missed during pause
  const body = JSON.stringify({ task: `CATCH UP: Triage was paused since ${since}. Fetch all emails received since the last saved historyId and triage each one.` });
  const { code, stderr } = postWebhook('http://localhost:9092', body);
  if (code.startsWith('2')) console.log(c.green('  ✓ dispatched CATCH UP to ops-agent'));
  else {
    console.log(c.yellow(`  catch-up dispatch failed (HTTP ${code}) — ops-agent may not be listening`));
    if (stderr) console.log(c.dim('  stderr: ') + stderr);
  }
}

function cmdTriageReclassify(args) {
  const msgId = args.find(a => !a.startsWith('--'));
  if (!msgId) die('reclassify: missing <messageId>');
  // messageId validation: Gmail IDs are hex, 14-20 chars typically
  if (!/^[a-zA-Z0-9_-]{8,40}$/.test(msgId)) die(`reclassify: messageId looks invalid (got "${msgId}")`);
  const body = JSON.stringify({ task: `RECLASSIFY: ${msgId}` });
  const { code, stderr } = postWebhook('http://localhost:9092', body);
  if (code.startsWith('2')) console.log(c.green('✓ dispatched: ') + c.bold(`RECLASSIFY ${msgId}`));
  else {
    console.error(c.red(`✗ dispatch failed (HTTP ${code})`));
    if (stderr) console.error(c.dim('  stderr: ') + stderr);
    process.exit(1);
  }
}

function cmdTriageResolve(args) {
  const topic = args.filter(a => !a.startsWith('--')).join(' ').trim();
  if (!topic) die('resolve: missing <topic>. Usage: merlin triage resolve "<topic text>"');
  if (topic.length > 300) die('resolve: topic too long (>300 chars)');
  const body = JSON.stringify({ task: `RESOLVE P1: ${topic}`, source: 'merlin-triage-resolve' });
  const { code, stderr } = postWebhook('http://localhost:9092', body);
  if (code.startsWith('2')) console.log(c.green('✓ dispatched: ') + c.bold(`RESOLVE P1: ${topic}`));
  else {
    console.error(c.red(`✗ dispatch failed (HTTP ${code})`));
    if (stderr) console.error(c.dim('  stderr: ') + stderr);
    process.exit(1);
  }
}

// --- restart ---
const TMUX = 'tmux';

// Wrappers that send raw argv to tmux — no shell interpolation.
function tmuxRun(args) {
  const r = spawnSync(TMUX, args, { encoding: 'utf8' });
  return { ok: r.status === 0, stdout: r.stdout || '', stderr: r.stderr || '' };
}
function tmuxSend(target, keys) { return tmuxRun(['send-keys', '-t', target, ...keys]); }
function tmuxPaneCommand(paneIdx) {
  const r = tmuxRun(['list-panes', '-t', 'claude:0', '-F', '#{pane_index} #{pane_current_command}']);
  if (!r.ok) return null;
  const line = r.stdout.split('\n').find(l => l.startsWith(paneIdx + ' '));
  return line ? line.slice(2) : null;
}
function tmuxPaneCount() {
  const r = tmuxRun(['list-panes', '-t', 'claude:0']);
  return r.ok ? r.stdout.trim().split('\n').length : 0;
}

// Check if a TCP port is free by attempting to listen with `nc`.
function portFree(port, timeoutSec = 3) {
  const r = spawnSync('nc', ['-z', '-w', '1', 'localhost', String(port)], { encoding: 'utf8' });
  // nc exits 0 if connection succeeds (port IN USE). exits non-0 if free.
  return r.status !== 0;
}

function waitPortFree(port, maxSec = 4) {
  for (let i = 0; i < maxSec; i++) {
    if (portFree(port)) return true;
    execFileSync('sleep', ['1']);
  }
  return portFree(port);
}

function cmdRestart(args) {
  const target = args.find(a => !a.startsWith('--'));
  if (!target) die('restart: usage: merlin restart <ops|chat|hookdeck|session>');
  const CLAUDE = path.join(HOME, '.local/bin/claude');
  const NODE = 'node';
  const AGENT_DIR = path.join(TOOLS, 'agent');
  const SUPERVISOR_DIR = path.join(AGENT_DIR, 'supervisor');
  const CONFIG_DIR = path.join(AGENT_DIR, 'config');

  // Load config dynamically
  function loadAgentConfig(name) {
    const cfg = JSON.parse(fs.readFileSync(path.join(CONFIG_DIR, 'agents.json'), 'utf8')).agents[name];
    if (!cfg) die(`restart: agent '${name}' not in agents.json`);
    return cfg;
  }

  const configs = {
    chat: { idx: 0, cwd: path.join(AGENT_DIR, 'chat-agent'), ports_to_free: [] },
    ops: { idx: 1, cwd: SUPERVISOR_DIR, ports_to_free: [9090, 9092, 9093] },
    hookdeck: { idx: 2, cwd: AGENT_DIR, launch: 'hookdeck listen 9090 gmail-source', ports_to_free: [] },
  };

  // Session-level restart: kill tmux session, launchd rebuilds it.
  if (target === 'session') {
    console.log(c.dim('killing tmux session "claude" — launchd (ai.claude.session) will respawn with fresh panes...'));
    const killed = tmuxRun(['kill-session', '-t', 'claude']);
    if (!killed.ok && !killed.stderr.includes("can't find session")) {
      die(`kill-session failed: ${killed.stderr}`);
    }
    console.log(c.green('✓ session killed. Wait ~30s, then: merlin status'));
    return;
  }

  if (!tmuxRun(['has-session', '-t', 'claude']).ok) {
    die('tmux session "claude" is not running. Start: launchctl kickstart gui/$(id -u)/ai.claude.session OR merlin restart session');
  }

  const cfg = configs[target];
  if (!cfg) die(`restart: unknown target '${target}'. Use ops, chat, hookdeck, or session.`);

  const paneCount = tmuxPaneCount();
  const paneTarget = `claude:0.${cfg.idx}`;
  if (cfg.idx >= paneCount) {
    if (target === 'hookdeck') {
      console.log(c.yellow(`pane ${cfg.idx} missing (only ${paneCount} panes) — creating...`));
      const split = tmuxRun(['split-window', '-t', 'claude', '-v', '-c', cfg.cwd]);
      if (!split.ok) die(`split-window failed: ${split.stderr}`);
      tmuxRun(['select-layout', '-t', 'claude', 'even-vertical']);
    } else {
      die(`restart: pane ${cfg.idx} does not exist (session has only ${paneCount} panes)`);
    }
  } else {
    console.log(c.dim(`force-killing pane ${cfg.idx} (${target}) via tmux respawn-pane -k...`));
    const respawn = tmuxRun(['respawn-pane', '-k', '-c', cfg.cwd, '-t', paneTarget, 'zsh']);
    if (!respawn.ok) die(`respawn-pane failed: ${respawn.stderr}`);
  }

  execFileSync('sleep', ['1']);
  for (const port of cfg.ports_to_free) {
    if (!waitPortFree(port, 4)) {
      console.log(c.yellow(`  warning: port ${port} still held after 4s — launch may fail to bind`));
    }
  }

  let launchCmd;
  if (target === 'hookdeck') {
    launchCmd = cfg.launch;
  } else if (target === 'ops') {
    launchCmd = `${NODE} ${SUPERVISOR_DIR}/index.mjs --agent ops`;
  } else {
    // chat: interactive claude with dev-channels
    const acfg = loadAgentConfig('chat');
    const tools = acfg.allowedTools.map(t => /[*]/.test(t) ? `"${t}"` : t).join(' ');
    const channels = (acfg.devChannels || []).map(c => 'server:' + c).join(' ');
    launchCmd = `${CLAUDE} --model ${acfg.model} --dangerously-load-development-channels ${channels} --permission-mode ${acfg.permissionMode} --remote-control-session-name-prefix ${acfg.remoteControlPrefix} --allowedTools ${tools}`;
  }
  tmuxSend(paneTarget, [launchCmd, 'Enter']);

  console.log(c.green(`✓ ${target} relaunched in pane ${cfg.idx}`));
  if (target === 'chat') {
    console.log(c.dim('  launcher will auto-accept dev-channels prompt within ~5s'));
  }
  if (target === 'ops') {
    console.log(c.dim('  supervisor handles startup catchup automatically'));
  }
}

// --- arch ---
function cmdArch() {
  if (!fs.existsSync(ARCH_MD)) die('architecture.md not found');
  process.stdout.write(fs.readFileSync(ARCH_MD, 'utf8'));
}

// --- where ---
function cmdWhere(args) {
  const q = args.find(a => !a.startsWith('--'));
  if (!q) die('where: missing <name>');
  const ql = q.toLowerCase();
  const hits = [];
  // tasks
  for (const t of loadTasks()) {
    if (t.name.includes(ql) || t.webhook_task.toLowerCase().includes(ql) || t.phrases.some(p => p.includes(ql)))
      hits.push({ kind: 'task', name: t.name, location: t.trigger_script });
  }
  // services
  for (const s of loadServices()) {
    if ((s.name || '').includes(ql) || (s.label || '').toLowerCase().includes(ql))
      hits.push({ kind: 'service', name: s.name, location: s.plist || s.session || '' });
  }
  // files
  const findOut = shSafe(`find "${TOOLS}" -maxdepth 6 -type f -name "*${q}*" -not -path "*/node_modules/*" -not -path "*/vendor/*" -not -path "*/.git/*" -not -path "*/SourcePackages/*" 2>/dev/null`) || '';
  for (const line of findOut.trim().split('\n').filter(Boolean).slice(0, 20)) {
    hits.push({ kind: 'file', name: path.basename(line), location: line.replace(ROOT + '/', '') });
  }
  if (hasFlag(args, '--json')) { console.log(JSON.stringify(hits, null, 2)); return; }
  if (!hits.length) { console.log(c.yellow('no matches')); process.exit(1); }
  console.log(table(hits, ['kind', 'name', 'location']));
}

// --- doctor ---
function cmdDoctor(args) {
  const checks = [];
  const add = (name, ok, detail) => checks.push({ name, ok, detail });
  const tasks = loadTasks();
  const services = loadServices();

  // 1. cron entries → scripts exist
  const cron = shSafe('crontab -l') || '';
  const cronLines = cron.split('\n').filter(l => l.trim() && !l.startsWith('#'));
  const missingScripts = [];
  for (const line of cronLines) {
    const m = line.match(/(\/Users\/[^\s>]+\.(sh|mjs|js))/);
    if (!m) continue;
    if (!fs.existsSync(m[1])) missingScripts.push(m[1]);
  }
  add('cron → scripts exist', missingScripts.length === 0, missingScripts.length ? `missing: ${missingScripts.join(', ')}` : `${cronLines.length} cron entries, all targets exist`);

  // 2. trigger-*.sh → tasks.json
  const scriptsDir = path.join(TOOLS, 'agent/scripts');
  const triggerScripts = fs.readdirSync(scriptsDir).filter(f => f.startsWith('trigger-') && f.endsWith('.sh'));
  // check-*.sh that hit webhook also count as triggers
  const checkScripts = fs.readdirSync(scriptsDir).filter(f => f.startsWith('check-') && f.endsWith('.sh'));
  const allTriggers = [...triggerScripts, ...checkScripts];
  // Exclude event-driven scripts (not scheduled tasks) from orphan check
  const eventDriven = new Set(['trigger-startup-catchup.sh']);
  const orphans = allTriggers.filter(f => !eventDriven.has(f) && !tasks.some(t => t.trigger_script && t.trigger_script.endsWith(f)));
  add('trigger scripts in tasks.json', orphans.length === 0, orphans.length ? `orphans: ${orphans.join(', ')}` : `${allTriggers.length} trigger scripts, all registered`);

  // A task with paused_until = YYYY-MM-DD (or full ISO) is expected to be
  // absent from crontab until that date. When it passes, the check starts
  // enforcing again — forcing a resume/retire decision. Bare YYYY-MM-DD is
  // anchored to end-of-day in America/New_York (not UTC midnight, which
  // resumes ~4h early during EDT).
  const nowMs = Date.now();
  const ET_OFFSET_FMT = new Intl.DateTimeFormat('en-US', {
    timeZone: 'America/New_York', timeZoneName: 'shortOffset',
  });
  const pausedUntilMs = (val) => {
    if (!val) return null;
    if (!/^\d{4}-\d{2}-\d{2}$/.test(val)) {
      const ms = Date.parse(val);
      return Number.isFinite(ms) ? ms : null;
    }
    const [y, m, d] = val.split('-').map(Number);
    const nextUtc = Date.UTC(y, m - 1, d + 1);
    const tzPart = ET_OFFSET_FMT.formatToParts(new Date(nextUtc)).find(p => p.type === 'timeZoneName')?.value || 'GMT-5';
    const match = tzPart.match(/GMT([+-])(\d{1,2})(?::(\d{2}))?/);
    const sign = match?.[1] === '-' ? -1 : 1;
    const hrs = match ? parseInt(match[2], 10) : 5;
    const mins = match?.[3] ? parseInt(match[3], 10) : 0;
    return nextUtc - sign * (hrs * 60 + mins) * 60 * 1000;
  };
  const isPaused = (t) => {
    const until = pausedUntilMs(t.paused_until);
    return until !== null && until > nowMs;
  };
  const scheduledTasks = tasks.filter(t => t.schedule && t.schedule !== 'on-demand' && !isPaused(t));
  const pausedCount = tasks.filter(t => t.schedule && t.schedule !== 'on-demand' && isPaused(t)).length;
  const unscheduled = [];
  for (const t of scheduledTasks) {
    const want = path.basename(t.trigger_script);
    // Multi-schedule separator is " / " (space-slash-space). Require
    // whitespace on both sides so we don't split on the step-value "/" inside
    // "*/20 * * * *" etc.
    const schedParts = t.schedule.split(/\s+\/\s+/).map(s => s.trim()).filter(Boolean);
    const found = schedParts.every(sched => cronLines.some(l => l.includes(want) && l.startsWith(sched)));
    if (!found) unscheduled.push(t.name);
  }
  const pausedSuffix = pausedCount ? `, ${pausedCount} paused` : '';
  add('tasks.json schedules ↔ crontab', unscheduled.length === 0, unscheduled.length ? `missing cron: ${unscheduled.join(', ')}` : `${scheduledTasks.length} scheduled tasks, all in cron${pausedSuffix}`);

  // 4. ops_playbook_section headers exist
  const opsMd = fs.existsSync(OPS_CLAUDE) ? fs.readFileSync(OPS_CLAUDE, 'utf8') : '';
  const missingSections = tasks.filter(t => t.ops_playbook_section && !t.job && !new RegExp(`^## ${escRe(t.ops_playbook_section)}( \\(.*\\))?\\s*$`, 'm').test(opsMd)).map(t => `${t.name} → ${t.ops_playbook_section}`);
  add('ops playbook sections exist', missingSections.length === 0, missingSections.length ? `missing: ${missingSections.join('; ')}` : `${tasks.length} sections verified in ops-agent/CLAUDE.md`);

  // 5. services.json plists → exist
  const missingPlists = [];
  for (const s of services) {
    if (s.type !== 'launchagent') continue;
    const p = expandHome(s.plist);
    if (!fs.existsSync(p)) missingPlists.push(s.label);
  }
  add('services.json plists exist', missingPlists.length === 0, missingPlists.length ? `missing: ${missingPlists.join(', ')}` : `${services.filter(s => s.type === 'launchagent').length} plists verified`);

  // 6. no old Dev/Tools paths in tracked text files
  // Use git grep — it natively skips binary files and respects .gitignore.
  // Exclude files that legitimately contain the pattern (this tool + its test harness).
  const grepOut = shSafe('git grep -l -E "${MERLIN_HOME_USER}/Dev/Tools/|~/Dev/Tools/|\\$HOME/Dev/Tools/" -- ":!*.png" ":!*.jpg" ":!*.pdf" ":!*.p8" ":!*.provisionprofile" ":!bin/merlin" ":!system/test-merlin.sh" ":!system/architecture.md" || true', { cwd: ROOT }) || '';
  const badPaths = grepOut.split('\n').filter(Boolean);
  add('no Dev/Tools/ residuals in tracked files', badPaths.length === 0,
      badPaths.length ? `found in: ${badPaths.slice(0, 5).join(', ')}${badPaths.length > 5 ? ` (+${badPaths.length-5})` : ''}` : 'clean');

  // 7. phrase uniqueness
  const phraseMap = new Map();
  for (const t of tasks) for (const p of t.phrases) {
    const k = p.toLowerCase();
    if (!phraseMap.has(k)) phraseMap.set(k, []);
    phraseMap.get(k).push(t.name);
  }
  const dupes = [...phraseMap.entries()].filter(([_, v]) => v.length > 1);
  add('task phrases are unique', dupes.length === 0, dupes.length ? `shared: ${dupes.map(([p, ts]) => `"${p}" in [${ts.join(',')}]`).join('; ')}` : `${phraseMap.size} unique phrases`);

  // 8. trigger_script paths exist (skip tasks with null trigger_script — those are on-demand dispatch-only entries like mkt-outreach-apply)
  const missingTrigs = tasks.filter(t => t.trigger_script && !fs.existsSync(path.join(ROOT, t.trigger_script))).map(t => t.name);
  add('trigger_script paths exist', missingTrigs.length === 0, missingTrigs.length ? `missing: ${missingTrigs.join(', ')}` : `${tasks.filter(t => t.trigger_script).length} trigger scripts verified`);

  // 9. process-manager running (check HTTP health endpoint — pgrep can't see cross-session processes on macOS)
  const pmHealth = shSafe('curl -sf --max-time 3 http://127.0.0.1:9095/health');
  add('process-manager running', !!pmHealth, pmHealth ? 'HTTP 200' : 'unreachable on :9095 — check launchd');

  // 10. supervisor health endpoints reachable
  const chatHealth = fetchJson('http://127.0.0.1:9094/health');
  add('chat supervisor reachable', !!chatHealth, chatHealth ? 'HTTP 200' : 'unreachable on :9094');
  const opsHealth = fetchJson('http://127.0.0.1:9093/health');
  add('ops supervisor reachable', !!opsHealth, opsHealth ? 'HTTP 200' : 'unreachable on :9093');

  // 11. MCP configs are valid JSON
  for (const name of ['chat-mcp-config.json', 'mcp-config.json']) {
    const p = path.join(TOOLS, 'agent/supervisor', name);
    let valid = false;
    try { JSON.parse(fs.readFileSync(p, 'utf8')); valid = true; } catch {}
    add(`${name} valid`, valid, valid ? 'valid JSON' : 'missing or invalid');
  }

  // 12. CLAUDE.md freshness — each agent's CLAUDE.md shouldn't be newer than
  // its current session. The supervisor exposes sessionStartedAt (set on each
  // startSession call including graceful restarts) — prefer that over the
  // supervisor-process startedAt so graceful restarts clear the STALE state.
  // Very recent edits (< CLAUDE_MD_GRACE_MIN) are treated as "pending restart"
  // rather than STALE: they're an active-editing state, not a stale-config
  // running-in-production state. True operational staleness means the file
  // was changed long ago and the supervisor was never bounced to pick it up.
  const CLAUDE_MD_GRACE_MIN = 10;
  for (const [name, port, relPath] of [
    ['chat', 9094, 'agent/chat-agent/CLAUDE.md'],
    ['ops', 9093, 'agent/ops-agent/CLAUDE.md'],
  ]) {
    const cmdPath = path.join(TOOLS, relPath);
    let ok = false;
    let status = null;
    try {
      const health = fetchJson(`http://127.0.0.1:${port}/health`) || {};
      const sessionTs = health.sessionStartedAt || health.startedAt;
      const ref = sessionTs ? new Date(sessionTs).getTime() : 0;
      const mtime = fs.statSync(cmdPath).mtimeMs;
      const ageMin = (Date.now() - mtime) / 60000;
      if (!ref) { ok = false; status = 'supervisor unreachable'; }
      else if (mtime <= ref) { ok = true; status = 'fresh'; }
      else if (ageMin < CLAUDE_MD_GRACE_MIN) {
        ok = true;
        status = `fresh (edited ${ageMin.toFixed(0)}min ago — within ${CLAUDE_MD_GRACE_MIN}min grace, pending restart)`;
      } else {
        ok = false;
        status = `STALE — CLAUDE.md edited ${ageMin.toFixed(0)}min ago, session started ${new Date(ref).toISOString()}`;
      }
    } catch (err) { ok = false; status = `check failed: ${err.message}`; }
    add(`${name} CLAUDE.md fresh`, ok, status);
  }

  // 13. hum liveness — hum fires 5x/day at 10:30, 12:30, 15:30, 17:30, 22:30 local.
  // Longest natural gap inside waking hours is ~5h (17:30 → 22:30) + jitter, so 7h stale is broken.
  // Check only inside 11:00-22:59 local to avoid false positives during overnight sleep window.
  const humRunsPath = path.join(TOOLS, 'data/hum-runs.jsonl');
  const hour = new Date().getHours();
  const inWakingCheck = hour >= 11 && hour < 23;
  if (!inWakingCheck) {
    add('hum liveness', true, `skipped (outside 11:00–23:00 check window, now ${hour}:00)`);
  } else {
    let raw = null;
    try { raw = fs.readFileSync(humRunsPath, 'utf8'); }
    catch (e) { if (e.code !== 'ENOENT') add('hum liveness', false, `read failed: ${e.message}`); }
    if (raw !== null) {
      const lines = raw.split('\n').filter(Boolean);
      let lastTs = null;
      for (let i = lines.length - 1; i >= 0; i--) {
        try { const r = JSON.parse(lines[i]); if (r.ts) { lastTs = r.ts; break; } } catch {}
      }
      if (!lastTs) {
        add('hum liveness', true, 'no runs yet (fresh install)');
      } else {
        const ageH = (Date.now() - new Date(lastTs).getTime()) / 3600000;
        const stale = ageH > 7;
        add('hum liveness', !stale, stale
          ? `STALE — last run ${ageH.toFixed(1)}h ago; expect a run every ~2h during waking hours`
          : `last run ${ageH.toFixed(1)}h ago (${new Date(lastTs).toLocaleString()})`);
      }
    } else if (raw === null && !checks.some(c => c.name === 'hum liveness')) {
      add('hum liveness', true, 'hum not installed (no hum-runs.jsonl)');
    }
  }

  // 14. Chrome DevTools Protocol reachable (port 9222).
  // The ops-agent's chrome-devtools MCP uses --autoConnect, which requires
  // Chrome to be running with --remote-debugging-port enabled on a non-default
  // user data directory. Without CDP reachable, any mcp__chrome-devtools__*
  // tool call hangs until the supervisor's 10-min TURN WATCHDOG trips.
  // Detecting this up-front in doctor surfaces the state anytime the user
  // runs it; the chrome-cdp-watch cron owns transition-triggered alerting.
  // Probe uses `localhost` (not 127.0.0.1): Chrome 147 silently binds an IPv4
  // stub on :9222 from the user's interactive profile that 404s on every CDP
  // path. `localhost` resolves to ::1 first on macOS and hits the LaunchAgent
  // automation Chrome (com.merlin.chrome-cdp) which binds IPv6 :9222.
  const cdpProbe = shSafe('curl -s --max-time 5 -o /dev/null -w "%{http_code}" http://localhost:9222/json/version 2>/dev/null') || '000';
  const cdpUp = cdpProbe === '200';
  add('chrome CDP port reachable', cdpUp, cdpUp
    ? 'HTTP 200 on :9222/json/version'
    : `HTTP ${cdpProbe} on :9222 — automation Chrome not running. Check LaunchAgent: launchctl list | grep com.merlin.chrome-cdp. Browser-automation jobs (broadway-lottery etc.) will skip until this clears.`);

  // 15. gog tasks CLI reachable. The 2026-04-29 review documented memories
  // #914/#920 falsely flagging "gog CLI unavailable" because the symlink
  // target was inspected instead of the actual binary. Probe by invoking a
  // no-op subcommand: a non-zero exit surfaces real auth/binary regressions
  // (renamed binary, expired token bucket) without reading the symlink.
  const gogProbe = shSafe('gog tasks lists --plain --account=${MERLIN_OWNER_EMAIL} --no-input 2>&1 | head -3');
  const gogOk = gogProbe && !/no auth|missing|not found|error/i.test(gogProbe);
  add('gog tasks CLI reachable', !!gogOk, gogOk
    ? `lists fetched (${gogProbe.split('\n').filter(Boolean).length} rows)`
    : `gog tasks list failed: ${(gogProbe || '<empty>').slice(0, 160)}. Re-auth via 'gog auth add ${MERLIN_OWNER_EMAIL} --services tasks' or fall back to service account.`);

  if (hasFlag(args, '--json')) { console.log(JSON.stringify(checks, null, 2)); process.exit(checks.every(c => c.ok) ? 0 : 1); }

  // --repair: auto-fix repairable drift (schedule mismatches + orphan scripts in cron)
  if (hasFlag(args, '--repair')) {
    const raw = JSON.parse(fs.readFileSync(TASKS_JSON, 'utf8'));
    const mutableTasks = raw.tasks;
    let repaired = 0;

    // Build cron map: triggerBasename -> [schedule strings]
    const cronMapR = {};
    for (const line of cronLines) {
      const scriptMatch = line.match(/trigger-[\w-]+\.sh/);
      if (!scriptMatch) continue;
      const bname = scriptMatch[0];
      const parts = line.trim().split(/\s+/);
      const sched = parts.slice(0, 5).join(' ');
      if (!cronMapR[bname]) cronMapR[bname] = [];
      cronMapR[bname].push(sched);
    }

    // Fix schedule mismatches
    for (const t of mutableTasks) {
      if (!t.trigger_script || !t.schedule || t.schedule === 'on-demand') continue;
      const bname = t.trigger_script.split('/').pop();
      const actual = cronMapR[bname];
      if (!actual) continue;
      const taskParts = t.schedule.split(/\s+\/\s+/).map(s => s.trim()).sort();
      const actualParts = actual.slice().sort();
      if (JSON.stringify(taskParts) !== JSON.stringify(actualParts)) {
        const newSched = actual.length === 1 ? actual[0] : actual.join(' / ');
        console.log(`  repair: ${t.name} schedule "${t.schedule}" → "${newSched}"`);
        t.schedule = newSched;
        repaired++;
      }
    }

    // Register orphan scripts (in cron, not in tasks.json)
    const taskScriptsR = new Set(mutableTasks.map(t => t.trigger_script && t.trigger_script.split('/').pop()).filter(Boolean));
    for (const [bname, scheds] of Object.entries(cronMapR)) {
      if (taskScriptsR.has(bname)) continue;
      const scriptPath = path.join(TOOLS, 'agent/scripts', bname);
      if (!fs.existsSync(scriptPath)) continue;
      // Read the first comment line for a description
      let desc = '';
      try { const lines = fs.readFileSync(scriptPath, 'utf8').split('\n'); for (const l of lines) { const m = l.match(/^#\s*(.+)/); if (m && !m[1].startsWith('!')) { desc = m[1].trim(); break; } } } catch {}
      const taskName = bname.replace(/^trigger-/, '').replace(/\.sh$/, '');
      const newSched = scheds.length === 1 ? scheds[0] : scheds.join(' / ');
      const entry = {
        name: taskName,
        schedule: newSched,
        schedule_human: newSched,
        trigger_script: `agent/scripts/${bname}`,
        webhook_url: 'http://localhost:9092',
        webhook_task: taskName.toUpperCase().replace(/-/g, ' '),
        ops_playbook_section: null,
        delivers_to: 'unknown',
        phrases: [],
        description: desc || `Auto-registered by doctor --repair on ${new Date().toISOString().slice(0,10)}.`,
        job: taskName,
      };
      console.log(`  repair: registered orphan ${taskName} @ ${newSched}`);
      mutableTasks.push(entry);
      repaired++;
    }

    if (repaired > 0) {
      fs.writeFileSync(TASKS_JSON, JSON.stringify(raw, null, 2) + '\n');
      console.log(c.green(`\n  ${repaired} repair(s) applied to tasks.json. Run 'merlin doctor' to verify.`));
    } else {
      console.log(c.dim('  nothing to repair'));
    }
    process.exit(0);
  }

  let failed = 0;
  for (const ck of checks) {
    const mark = ck.ok ? c.green('✓') : c.red('✗');
    console.log(`${mark} ${c.bold(ck.name)}`);
    console.log(`  ${c.dim(ck.detail)}`);
    if (!ck.ok) failed++;
  }
  console.log('');
  if (failed === 0) console.log(c.green(`${checks.length}/${checks.length} checks passed`));
  else { console.log(c.red(`${failed}/${checks.length} checks FAILED`)); process.exit(1); }
}

function escRe(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

// --- hum ---
const HUM_STATE   = path.join(TOOLS, 'data/hum-state.json');
const HUM_SEEN    = path.join(TOOLS, 'data/hum-seen.json');
const HUM_FEEDBK  = path.join(TOOLS, 'data/hum-feedback.jsonl');
const HUM_RUNS    = path.join(TOOLS, 'data/hum-runs.jsonl');
const HUM_REACTION_ALIASES = {
  '👍':'helpful', 'helpful':'helpful', 'good':'helpful', 'yes':'helpful',
  '👎':'skip', 'skip':'skip', 'bad':'skip', 'no':'skip',
  '💤':'snooze', 'snooze':'snooze',
  'more':'more', 'more_of_these':'more', 'more of these':'more',
  // iOS tapback tokens (phone-channel forwards these raw from
  // merlin_messages.reaction). Match the semantic intent the client exposes
  // (Great / Useful / Not Useful) to the existing hum vocabulary.
  '❤️':'more', 'heart':'more',
  'thumbs_up':'helpful',
  'thumbs_down':'skip',
};

function loadHumState() {
  try { return JSON.parse(fs.readFileSync(HUM_STATE, 'utf8')); }
  catch (e) {
    if (e.code === 'ENOENT') die(`hum state not found at ${HUM_STATE}. Is hum installed?`);
    throw e;
  }
}
function saveHumState(s) {
  const tmp = HUM_STATE + '.tmp.' + process.pid;
  fs.writeFileSync(tmp, JSON.stringify(s, null, 2));
  fs.renameSync(tmp, HUM_STATE);
}
function parseHumDuration(s) {
  if (!s) return null;
  const now = Date.now();
  const lc = s.toLowerCase().trim();
  if (lc === 'today' || lc === 'end-of-day') {
    const d = new Date(); d.setHours(23, 59, 59, 999);
    return d.toISOString();
  }
  if (lc === 'until-morning' || lc === 'morning') {
    const d = new Date();
    if (d.getHours() >= 9) d.setDate(d.getDate() + 1);
    d.setHours(9, 0, 0, 0);
    return d.toISOString();
  }
  if (lc === 'weekend' || lc === 'until-monday') {
    const d = new Date();
    const day = d.getDay();
    const daysToMonday = day === 1 ? 7 : (8 - day) % 7 || 7;
    d.setDate(d.getDate() + daysToMonday);
    d.setHours(9, 0, 0, 0);
    return d.toISOString();
  }
  const m = lc.match(/^(\d+)\s*(m|min|h|hr|d|day|days)$/);
  if (m) {
    const n = parseInt(m[1], 10);
    const unit = m[2];
    const ms = unit.startsWith('m') && !unit.startsWith('min') ? n * 60 * 1000
             : unit.startsWith('min') ? n * 60 * 1000
             : unit.startsWith('h') ? n * 60 * 60 * 1000
             : n * 24 * 60 * 60 * 1000;
    return new Date(now + ms).toISOString();
  }
  const iso = new Date(s);
  if (!isNaN(iso.getTime())) return iso.toISOString();
  return null;
}
function formatHumTime(iso) {
  if (!iso) return c.dim('—');
  const d = new Date(iso);
  if (isNaN(d.getTime())) return iso;
  const mins = Math.round((Date.now() - d.getTime()) / 60000);
  if (mins < 1) return `${d.toLocaleString()} ${c.dim('(just now)')}`;
  if (mins < 60) return `${d.toLocaleString()} ${c.dim(`(${mins}m ago)`)}`;
  const hrs = Math.round(mins / 60);
  if (hrs < 48) return `${d.toLocaleString()} ${c.dim(`(${hrs}h ago)`)}`;
  return `${d.toLocaleString()} ${c.dim(`(${Math.round(hrs/24)}d ago)`)}`;
}

function cmdHum(args) {
  const sub = args[0];
  if (!sub || sub === 'help' || sub === '--help') return cmdHumHelp();
  const subs = {
    status: cmdHumStatus,
    pause: cmdHumPause,
    resume: cmdHumResume,
    feedback: cmdHumFeedback,
    runs: cmdHumRuns,
    review: cmdHumReview,
    test: cmdHumTest,
    tune: cmdHumTune,
    question: cmdHumQuestion,
    learn: cmdHumLearn,
    learnings: cmdHumLearnings,
    situation: cmdHumSituation,
    insight: cmdHumInsight,
    audit: cmdHumAudit,
  };
  const fn = subs[sub];
  if (!fn) die(`unknown: hum ${sub}. Try: merlin hum help`);
  fn(args.slice(1));
}

