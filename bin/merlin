  console.log(c.bold('merlin hum') + ' — proactive check-in subsystem\n');
  console.log('  status                       show next run, today\'s pings, cool-down, pause state, threshold');
  console.log('  pause <duration>             "2h" | "30m" | "today" | "until-morning" | "weekend" | "<ISO>"');
  console.log('  resume                       unpause');
  console.log('  feedback <ping-id> <reaction>  record reaction: helpful | skip | snooze | more | 👍 | 👎');
  console.log('    (use ping-id "last" to reference the most recent ping)');
  console.log('  runs [--tail N]              tail hum-runs.jsonl (default 10)');
  console.log('  review [--since Nd]          what was surfaced / reacted to (default 7d)');
  console.log('  test                         fire a one-shot tick via webhook');
  console.log('  tune                         show current config + feedback bias');
  console.log('  question                     show current pending question (or null)');
  console.log('  learn <id> <answer>          record a manual answer for the pending question');
  console.log('  learnings [--tail N]         tail hum-learnings.jsonl (default 10)');
  console.log('  situation [--json]           composite snapshot: where/env/time/now/next/working-on');
  console.log('  insight [--since Nd]         aggregate last N days of tick traces into metrics (default 7d)');
  console.log('  audit [--window 24h|7d] [--json]  drift check: outcome.sent count vs hum-feedback entries\n');
  console.log(c.dim('State files:'));
  console.log(c.dim(`  ${HUM_STATE}`));
  console.log(c.dim(`  ${HUM_SEEN}`));
  console.log(c.dim(`  ${HUM_FEEDBK}`));
  console.log(c.dim(`  ${HUM_RUNS}`));
}

function cmdHumStatus(args) {
  const s = loadHumState();
  if (hasFlag(args, '--json')) { console.log(JSON.stringify(s, null, 2)); return; }
  console.log(c.bold('Hum Status') + '\n');
  if (s.pause && s.pause.until && new Date(s.pause.until) > new Date()) {
    console.log(`  ${c.yellow('PAUSED')} until ${new Date(s.pause.until).toLocaleString()}`);
    if (s.pause.reason) console.log(`  reason:  ${s.pause.reason}`);
  } else {
    console.log(`  state:   ${c.green('active')}`);
  }
  const minIntMin = s.min_ping_interval_minutes ?? 60;
  if (s.last_ping_at) {
    const lastPingMs = Date.now() - new Date(s.last_ping_at).getTime();
    const minMs = minIntMin * 60 * 1000;
    if (lastPingMs < minMs) {
      const m = Math.round((minMs - lastPingMs) / 60000);
      console.log(`  min-interval: ${c.yellow(`${m}m remaining`)} (${minIntMin}m)`);
    } else {
      console.log(`  min-interval: ${c.green('clear')} (${minIntMin}m)`);
    }
  }
  const today = s.today || {};
  const cap = s.max_pings_per_day ?? 4;
  const capColor = (today.pings || 0) >= cap ? c.red : c.green;
  const runs = today.runs || 0;
  const pings = today.pings || 0;
  const questions = today.questions || 0;
  const logOnly = today.log_only || 0;
  console.log(`  today:    ${runs} ticks, ${capColor(`${pings}/${cap} pings`)}, ${questions} questions, ${logOnly} log-only`);
  console.log(`  last run: ${formatHumTime(s.last_run_at)}`);
  console.log(`  last ping: ${formatHumTime(s.last_ping_at)}`);

  // Pending question, if any
  try {
    const raw = fs.readFileSync(HUM_PENDING_Q, 'utf8').trim();
    if (raw && raw !== 'null') {
      const q = JSON.parse(raw);
      const exp = new Date(q.expires_at);
      const remMin = Math.round((exp.getTime() - Date.now()) / 60000);
      const status = remMin > 0 ? c.yellow(`${remMin}m left`) : c.red('EXPIRED');
      console.log(`  pending question: ${c.bold(q.subject)} [${status}]`);
    }
  } catch {}

  // Last outbound Merlin message stamp
  try {
    const stamp = JSON.parse(fs.readFileSync(path.join(TOOLS, 'data/last-merlin-message-at.json'), 'utf8'));
    if (stamp.ts) console.log(`  last outbound msg: ${formatHumTime(stamp.ts)}`);
  } catch {}
}

function cmdHumPause(args) {
  const durStr = args[0];
  if (!durStr) die('hum pause: duration required (e.g. "2h", "today", "until-morning", "weekend")');
  const until = parseHumDuration(durStr);
  if (!until) die(`hum pause: could not parse duration "${durStr}"`);
  const s = loadHumState();
  s.pause = { until, reason: args.slice(1).join(' ') || null, set_at: new Date().toISOString() };
  saveHumState(s);
  console.log(`${c.yellow('Paused')} until ${new Date(until).toLocaleString()}`);
}

function cmdHumResume(args) {
  const s = loadHumState();
  if (!s.pause) { console.log(c.dim('hum was not paused')); return; }
  s.pause = null;
  saveHumState(s);
  console.log(c.green('Resumed'));
}

// Advisory lock around hum-feedback.jsonl. Must match the lockfile path used
// by bin/hum-ping so reaction updates and ping appends serialize — a
// naïve read-modify-write here would otherwise silently clobber a concurrent
// append from a freshly-sent hum ping.
const HUM_FEEDBK_LOCK = path.join(TOOLS, 'data/.hum-feedback.lock');
function humFeedbackLockAcquire(timeoutMs = 5000) {
  const start = Date.now();
  while (Date.now() - start < timeoutMs) {
    try { fs.mkdirSync(HUM_FEEDBK_LOCK); return true; }
    catch (e) {
      if (e.code !== 'EEXIST') throw e;
      try {
        const age = Date.now() - fs.statSync(HUM_FEEDBK_LOCK).mtimeMs;
        if (age > 30_000) { try { fs.rmdirSync(HUM_FEEDBK_LOCK); } catch {} continue; }
      } catch {}
      const until = Date.now() + 20 + Math.floor(Math.random() * 30);
      while (Date.now() < until) { /* spin */ }
    }
  }
  return false;
}
function humFeedbackLockRelease() { try { fs.rmdirSync(HUM_FEEDBK_LOCK); } catch {} }

function cmdHumFeedback(args) {
  let pingId = args[0];
  const reaction = args[1];
  if (!pingId || !reaction) die('hum feedback <ping-id|last> <reaction>');
  const norm = HUM_REACTION_ALIASES[reaction.toLowerCase()] || reaction;

  if (!humFeedbackLockAcquire()) {
    console.error(c.yellow('warn') + ': could not acquire hum-feedback lock after 5s; proceeding anyway');
  }

  let raw;
  try { raw = fs.readFileSync(HUM_FEEDBK, 'utf8'); }
  catch (e) {
    humFeedbackLockRelease();
    if (e.code === 'ENOENT') die('no hum feedback log yet');
    throw e;
  }
  const lines = raw.split('\n');

  if (pingId === 'last') {
    for (let i = lines.length - 1; i >= 0; i--) {
      if (!lines[i].trim()) continue;
      try {
        const r = JSON.parse(lines[i]);
        if (r.ping_id) { pingId = r.ping_id; break; }
      } catch {}
    }
    if (pingId === 'last') die('no ping-id found in feedback log');
  }

  let found = false;
  const out = lines.map(line => {
    if (!line.trim()) return line;
    try {
      const r = JSON.parse(line);
      if (r.ping_id === pingId) {
        r.reaction = norm;
        r.reaction_at = new Date().toISOString();
        found = true;
        return JSON.stringify(r);
      }
      return line;
    } catch { return line; }
  });
  if (!found) {
    humFeedbackLockRelease();
    die(`no ping found with id "${pingId}"`);
  }

  const tmp = HUM_FEEDBK + '.tmp.' + process.pid;
  try {
    fs.writeFileSync(tmp, out.join('\n'));
    fs.renameSync(tmp, HUM_FEEDBK);
  } finally {
    humFeedbackLockRelease();
  }
  console.log(`${c.green('Recorded')} reaction "${norm}" for ${pingId}`);

  // Reinforcement loop: if the ping originated from an idea, append the
  // reaction to hum-ideas.jsonl so the next ideation run can read it and
  // bias generation. See system/hum-ideas-reservoir.md.
  try {
    const ideasFile = path.join(TOOLS, 'data/hum-ideas.jsonl');
    const ideaRaw = fs.readFileSync(ideasFile, 'utf8');
    const ideaLines = ideaRaw.split('\n').filter(Boolean);
    let matchedIdeaId = null;
    for (const line of ideaLines) {
      try {
        const r = JSON.parse(line);
        if (r.ping_id === pingId && r.id) { matchedIdeaId = r.id; break; }
      } catch {}
    }
    if (matchedIdeaId) {
      const reactionRecord = {
        id: matchedIdeaId,
        reaction: norm,
        reacted_at: new Date().toISOString(),
        ping_id: pingId,
      };
      fs.appendFileSync(ideasFile, JSON.stringify(reactionRecord) + '\n');
      console.log(c.dim(`  → linked to idea ${matchedIdeaId}`));
    }
  } catch (e) {
    if (e.code !== 'ENOENT') console.error(c.dim(`  (idea-link warn: ${e.message})`));
  }
}

function cmdHumRuns(args) {
  const tailStr = getFlag(args, '--tail', '10');
  const tail = Math.max(1, parseInt(tailStr, 10) || 10);
  let raw;
  try { raw = fs.readFileSync(HUM_RUNS, 'utf8'); }
  catch (e) { if (e.code === 'ENOENT') { console.log(c.dim('(no runs yet)')); return; } throw e; }
  const lines = raw.split('\n').filter(Boolean);
  const recent = lines.slice(-tail);
  if (!recent.length) { console.log(c.dim('(no runs yet)')); return; }
  const rows = recent.map(line => {
    try {
      const r = JSON.parse(line);
      const modeColor = r.mode === 'ping' ? c.green : (r.mode === 'error' ? c.red : c.dim);
      return {
        ts: String(r.ts || '').slice(0, 19),
        mode: modeColor(r.mode || '?'),
        lane: r.lane_rotated || '—',
        top: r.top_score != null ? r.top_score.toFixed(2) : '—',
        decision: r.decision || '—',
        reason: r.deferral_reason || c.dim('—'),
      };
    } catch { return { ts: c.dim('(unparsable)'), mode: '', lane: '', top: '', decision: '', reason: '' }; }
  });
  console.log(table(rows, ['ts', 'mode', 'lane', 'top', 'decision', 'reason']));
}

function cmdHumReview(args) {
  const sinceStr = getFlag(args, '--since', '7d');
  const m = String(sinceStr).match(/^(\d+)([hd])$/);
  const since = new Date();
  if (m) {
    const n = parseInt(m[1], 10);
    if (m[2] === 'h') since.setHours(since.getHours() - n);
    else since.setDate(since.getDate() - n);
  } else { since.setDate(since.getDate() - 7); }
  let raw;
  try { raw = fs.readFileSync(HUM_FEEDBK, 'utf8'); }
  catch (e) { if (e.code === 'ENOENT') { console.log(c.dim('(no feedback log yet)')); return; } throw e; }
  const lines = raw.split('\n').filter(Boolean);
  const entries = lines.map(l => { try { return JSON.parse(l); } catch { return null; } }).filter(Boolean)
                       .filter(e => e.sent_at && new Date(e.sent_at) >= since);
  console.log(c.bold(`Hum review — since ${since.toLocaleString()}`) + '\n');
  console.log(`  total pings: ${entries.length}`);
  const byLane = {}, byReact = { helpful: 0, skip: 0, snooze: 0, more: 0, silence: 0, none: 0 };
  for (const e of entries) {
    byLane[e.lane] = (byLane[e.lane] || 0) + 1;
    const r = e.reaction || (e.reaction_at ? 'silence' : 'none');
    byReact[r] = (byReact[r] || 0) + 1;
  }
  console.log('\n  ' + c.bold('By reaction:'));
  for (const [k, v] of Object.entries(byReact)) console.log(`    ${k}: ${v}`);
  console.log('\n  ' + c.bold('By lane:'));
  for (const [k, v] of Object.entries(byLane)) console.log(`    ${k}: ${v}`);
}

function cmdHumTest(args) {
  const lane = getFlag(args, '--lane', null);
  const payload = lane ? JSON.stringify({ job: 'hum', force_lane: lane }) : JSON.stringify({ job: 'hum' });
  console.log(c.dim(`Dispatching hum to http://localhost:9092 (bypasses jitter)...`));
  const res = shSafe(`curl -sf --max-time 5 -X POST http://localhost:9092 -H "Content-Type: application/json" -d '${payload}'`);
  if (res === null) die('dispatch failed — is the ops supervisor running? Check: merlin status');
  console.log(c.green('Dispatched.') + ' Tail progress: ' + c.dim('merlin hum runs --tail 5'));
}

function cmdHumTune(args) {
  const s = loadHumState();
  console.log(c.bold('Hum tuning') + '\n');
  console.log(`  min_ping_interval_minutes: ${s.min_ping_interval_minutes ?? 60}`);
  console.log(`  max_pings_per_day: ${s.max_pings_per_day ?? 4}`);
  console.log(`  schema_version: ${s.schema_version ?? 1}`);
  console.log(c.dim('\nTo edit: modify ' + HUM_STATE + ' directly and save.'));
  console.log(c.dim('Weekly hum-review proposes tuning based on reactions + answer rates.'));
}

// --- cost ---
function cmdCost(args) {
  const data = shSafe('curl -sf --max-time 3 http://127.0.0.1:9093/cost');
  if (!data) { die('supervisor not reachable on :9093. Is the ops-supervisor running?'); return; }
  const j = JSON.parse(data);
  if (hasFlag(args, '--json')) { console.log(JSON.stringify(j, null, 2)); return; }
  console.log(c.bold('Ops Agent Cost') + '\n');
  console.log(`  today:   $${j.todayUsd?.toFixed(4) || '0.0000'}`);
  console.log(`  week:    $${j.weekUsd?.toFixed(4) || '0.0000'}`);
  console.log(`  total:   $${j.totalUsd?.toFixed(4) || '0.0000'}`);
  if (j.perModel && Object.keys(j.perModel).length) {
    console.log(`\n  ${c.bold('Per model:')}`);
    for (const [m, cost] of Object.entries(j.perModel)) {
      console.log(`    ${m}: $${cost.toFixed(4)}`);
    }
  }
  console.log(`  entries: ${j.entries || 0}`);
}

const HUM_PENDING_Q = path.join(HOME, 'dev/merlin/data/hum-pending-question.json');
const HUM_LEARNINGS = path.join(HOME, 'dev/merlin/data/hum-learnings.jsonl');
const HUM_ANSWER_BIN = path.join(HOME, 'dev/merlin/bin/hum-answer');

function cmdHumQuestion(args) {
  try {
    const raw = require('fs').readFileSync(HUM_PENDING_Q, 'utf8').trim();
    if (!raw || raw === 'null') { console.log(c.dim('(no pending question)')); return; }
    const q = JSON.parse(raw);
    if (hasFlag(args, '--json')) { console.log(JSON.stringify(q, null, 2)); return; }
    console.log(c.bold('Pending Question') + '\n');
    console.log(`  id:           ${q.id}`);
    console.log(`  asked_at:     ${q.asked_at}`);
    console.log(`  expires_at:   ${q.expires_at}`);
    console.log(`  subject:      ${q.subject}`);
    console.log(`  memory_hook:  ${q.memory_hook}`);
    console.log(`\n  ${q.question}`);
  } catch (e) {
    if (e.code === 'ENOENT') { console.log(c.dim('(no pending question)')); return; }
    throw e;
  }
}

function cmdHumLearn(args) {
  const [id, ...rest] = args;
  const answer = rest.join(' ').trim();
  if (!id || !answer) die('hum learn <id> <answer>');
  const { spawnSync } = require('child_process');
  const r = spawnSync(HUM_ANSWER_BIN, [id, answer], { encoding: 'utf8' });
  if (r.stdout) process.stdout.write(r.stdout);
  if (r.stderr) process.stderr.write(r.stderr);
  process.exit(r.status ?? 0);
}

function cmdHumLearnings(args) {
  let n = 10;
  for (let i = 0; i < args.length; i++) if (args[i] === '--tail' && args[i + 1]) n = parseInt(args[++i], 10);
  try {
    const lines = require('fs').readFileSync(HUM_LEARNINGS, 'utf8').trim().split('\n').filter(Boolean);
    const tail = lines.slice(-n);
    if (hasFlag(args, '--json')) { console.log(tail.join('\n')); return; }
    console.log(c.bold(`Last ${tail.length} hum learnings`) + '\n');
    for (const line of tail) {
      const r = JSON.parse(line);
      const d = new Date(r.answered_at).toLocaleString();
      console.log(`${c.dim(d)}  ${c.bold(r.subject)}  [${r.memory_hook}]`);
      console.log(`  Q: ${r.question.slice(0, 140)}`);
      console.log(`  A: ${r.answer.slice(0, 200)}\n`);
    }
  } catch (e) {
    if (e.code === 'ENOENT') { console.log(c.dim('(no learnings yet)')); return; }
    throw e;
  }
}

// Composite situation snapshot for hum. Gathers where/environment/time/
// activity/next/working-on signals. Cached 2 min in TMPDIR so multiple
// callers within a tick share one computation.
const SITUATION_CACHE = path.join(process.env.TMPDIR || '/tmp', 'merlin-situation.json');

function readJsonSafe(p) {
  try { return JSON.parse(require('fs').readFileSync(p, 'utf8')); } catch { return null; }
}

function buildSituation() {
  const fs = require('fs');
  const tz = readJsonSafe(path.join(TOOLS, 'data/user-timezone.json'))?.timezone || 'America/New_York';
  const cursor = readJsonSafe(path.join(TOOLS, 'data/phone-channel-cursor.json'));
  const lastInboundMs = cursor?.lastSeenAt ? Date.now() - new Date(cursor.lastSeenAt).getTime() : null;
  const inboundMinAgo = lastInboundMs !== null ? Math.round(lastInboundMs / 60000) : null;
  const lastOut = readJsonSafe(path.join(TOOLS, 'data/last-merlin-message-at.json'));
  const outboundMinAgo = lastOut?.ts ? Math.round((Date.now() - new Date(lastOut.ts).getTime()) / 60000) : null;

  const activity = inferActivityState();

  // Phone context (audio + motion) — returns null if stale / absent
  let phoneCtx = null;
  try {
    phoneCtx = JSON.parse(shSafe(
      `node -e "require('${path.join(TOOLS, 'lib/phone-context.js')}').getLatest().then(r=>console.log(JSON.stringify(r)))"`
    ) || 'null');
  } catch {}

  // Sleep/wake inference — actual wake-time today + last-active yesterday
  // from phone_unlocks + phone_context + merlin_messages. Closes context
  // gap cg-20260413-02. See lib/sleep-wake.js for source priority.
  let sleepWake = null;
  try {
    sleepWake = JSON.parse(shSafe(
      `node -e "require('${path.join(TOOLS, 'lib/sleep-wake.js')}').inferToday().then(r=>console.log(JSON.stringify(r)))"`
    ) || 'null');
  } catch {}

  // Current location via findme (single call; cached by findme itself)
  let location = null;
  try {
    const raw = shSafe(`"${path.join(TOOLS, 'bin/findme')}" locate --json`);
    location = JSON.parse(raw || 'null');
  } catch {}

  // Today's git commits (topic extraction)
  let todayCommits = [];
  try {
    const out = shSafe(`cd ${HOME}/dev/merlin && git log --oneline --since="today 00:00" --no-color 2>/dev/null`);
    todayCommits = (out || '').trim().split('\n').filter(Boolean).slice(0, 20);
  } catch {}

  // This-week commit topics — compact word-frequency of the last 7d commits'
  // subject lines (minus prefixes like "feat:"/"fix:" and small words). Top 5.
  let weekTopics = [];
  try {
    const raw = shSafe(`cd ${HOME}/dev/merlin && git log --since="7 days ago" --pretty=%s --no-color 2>/dev/null`) || '';
    const stop = new Set(['the','and','for','with','from','into','that','this','add','adds','added','fix','fixes','fixed','update','updates','updated','feat','chore','docs','test','tests','when','what','have','has','not','now','new','use','uses','used','one','two','all','any','via','per']);
    const freq = {};
    for (const line of raw.split('\n')) {
      const cleaned = line.replace(/^[a-z]+(\([^)]+\))?:/i, '').toLowerCase();
      for (const w of cleaned.split(/[^a-z0-9-]+/)) {
        if (w.length < 4 || stop.has(w)) continue;
        freq[w] = (freq[w] || 0) + 1;
      }
    }
    weekTopics = Object.entries(freq).sort((a,b) => b[1]-a[1]).slice(0, 5).map(([w]) => w);
  } catch {}

  // Weather, cached via apple-weather — skip if binary missing
  let weather = null;
  try {
    const w = shSafe(`"${path.join(TOOLS, 'bin/apple-weather')}" --findme --json 2>/dev/null`);
    if (w) {
      const parsed = JSON.parse(w);
      const cur = parsed?.currentWeather || parsed?.current || null;
      if (cur) weather = { temp_f: cur.temperature, condition: cur.conditionCode, uv: cur.uvIndex };
    }
  } catch {}

  // HID idle time — minutes since last keyboard/mouse/trackpad input on this
  // Mac. Signals "at desk actively" vs "stepped away / on phone / in a
  // meeting." `ioreg` returns nanoseconds.
  let atDeskMin = null;
  try {
    const raw = shSafe(`ioreg -c IOHIDSystem 2>/dev/null | awk '/HIDIdleTime/ {print $NF; exit}'`);
    const ns = parseInt(raw, 10);
    if (Number.isFinite(ns)) atDeskMin = Math.round(ns / 1e9 / 60);
  } catch {}

  // Next — what's coming up. Calendar events in [+0, +120min] plus today's
  // tasks summary. Feeds Sonnet's relevance overlay ("meeting in 30 min"
  // trumps most other candidates).
  let upcomingEvents = [];
  try {
    const raw = shSafe(`gog calendar list --account ${MERLIN_OWNER_EMAIL} --days 1 --max 20 --json 2>/dev/null`) || '';
    const data = JSON.parse(raw || '{}');
    const events = data?.events || data?.items || [];
    const now = Date.now();
    const horizon = now + 2 * 3600 * 1000;
    upcomingEvents = events
      .map((e) => {
        const start = new Date(e.start?.dateTime || e.start?.date || 0).getTime();
        const end = new Date(e.end?.dateTime || e.end?.date || 0).getTime();
        return { start, end, summary: e.summary || '(no title)', location: e.location || null };
      })
      .filter((e) => e.start && e.start >= now - 5 * 60000 && e.start <= horizon)
      .slice(0, 3)
      .map((e) => ({
        in_min: Math.round((e.start - now) / 60000),
        duration_min: Math.max(0, Math.round((e.end - e.start) / 60000)),
        summary: e.summary,
        location: e.location,
      }));
  } catch {}

  // Due-today + overdue tasks — lightweight counts + top-3 titles
  let dueToday = [], overdueCount = 0;
  try {
    const plain = shSafe(`gog tasks list @default --plain 2>/dev/null`) || '';
    const today = new Date().toISOString().slice(0, 10);
    for (const line of plain.split('\n').filter(Boolean)) {
      if (line.includes('completed')) continue;
      const m = line.match(/(\d{4}-\d{2}-\d{2})/);
      if (!m) continue;
      if (m[1] < today) overdueCount++;
      else if (m[1] === today) {
        // gog --plain is TSV; title is field 2
        const parts = line.split('\t');
        dueToday.push((parts[1] || line).slice(0, 80));
      }
    }
    dueToday = dueToday.slice(0, 3);
  } catch {}

  return {
    where: {
      lat: location?.latitude ?? null,
      lon: location?.longitude ?? null,
      place: location?.place_name || location?.placeName || null,
      companions: location?.companions || [],
      activity: location?.activity || null,
    },
    environment: {
      weather,
      audio_class: phoneCtx?.fresh ? phoneCtx.audio_class : null,
      db_bucket: phoneCtx?.fresh ? phoneCtx.ambient_db_bucket : null,
      motion_class: phoneCtx?.motion_class || null,
      phone_context_age_min: phoneCtx?.age_min ?? null,
    },
    time: {
      local_hour: activity.local_hour,
      tz: activity.local_tz,
      activity_state: activity.state,
      inbound_min_ago: inboundMinAgo,
      outbound_min_ago: outboundMinAgo,
      wake_time_today: sleepWake?.wake_time_today || null,
      sleep_time_yesterday: sleepWake?.sleep_time_yesterday || null,
      asleep_now: sleepWake?.asleep_now || false,
    },
    now_activity: {
      at_desk_min: atDeskMin,
    },
    next: {
      upcoming_events: upcomingEvents,
      tasks_due_today: dueToday,
      overdue_count: overdueCount,
    },
    working_on: {
      today_commits: todayCommits,
      week_commit_topics: weekTopics,
    },
  };
}

function cmdHumSituation(args) {
  const fs = require('fs');
  let snap = null;
  try {
    const stat = fs.statSync(SITUATION_CACHE);
    if (Date.now() - stat.mtimeMs < 120 * 1000) {
      snap = JSON.parse(fs.readFileSync(SITUATION_CACHE, 'utf8'));
    }
  } catch {}
  if (!snap || hasFlag(args, '--fresh')) {
    snap = buildSituation();
    try { fs.writeFileSync(SITUATION_CACHE, JSON.stringify(snap)); } catch {}
  }
  if (hasFlag(args, '--json')) { console.log(JSON.stringify(snap, null, 2)); return; }
  console.log(c.bold('Situation') + '\n');
  console.log(`  where:    ${snap.where.place || '—'}  (${snap.where.lat?.toFixed(3)}, ${snap.where.lon?.toFixed(3)})`);
  if (snap.where.companions?.length) console.log(`  with:     ${snap.where.companions.join(', ')}`);
  console.log(`  activity: ${snap.where.activity || '—'}`);
  console.log(`  state:    ${snap.time.activity_state}  (${snap.time.local_hour}:00 ${snap.time.tz})`);
  console.log(`  inbound:  ${snap.time.inbound_min_ago ?? '—'} min ago   outbound: ${snap.time.outbound_min_ago ?? '—'} min ago`);
  if (snap.time.wake_time_today) {
    console.log(`  woke:     ${snap.time.wake_time_today.hm}  (${snap.time.wake_time_today.source})`);
  }
  if (snap.time.sleep_time_yesterday) {
    console.log(`  to bed:   ${snap.time.sleep_time_yesterday.hm} y'day  (${snap.time.sleep_time_yesterday.source})`);
  }
  if (snap.environment.weather) console.log(`  weather:  ${snap.environment.weather.temp_f}F ${snap.environment.weather.condition}`);
  if (snap.environment.audio_class) console.log(`  audio:    ${snap.environment.audio_class}  (${snap.environment.db_bucket || '—'})`);
  if (snap.environment.motion_class) console.log(`  motion:   ${snap.environment.motion_class}`);
  if (snap.now_activity?.at_desk_min !== null && snap.now_activity?.at_desk_min !== undefined) {
    const d = snap.now_activity.at_desk_min;
    console.log(`  at desk:  ${d < 2 ? c.green('active now') : d + ' min idle'}`);
  }
  if (snap.next?.upcoming_events?.length) {
    console.log('\n  ' + c.bold('Next:'));
    for (const e of snap.next.upcoming_events) {
      const when = e.in_min < 0 ? 'started' : `in ${e.in_min}m`;
      console.log(`    ${when}  ${e.summary}${e.location ? ' @ ' + e.location : ''}`);
    }
  }
  if (snap.next?.tasks_due_today?.length || snap.next?.overdue_count) {
    console.log(`  tasks:    ${snap.next.overdue_count} overdue, ${snap.next.tasks_due_today?.length || 0} due today`);
  }
  if (snap.working_on.today_commits?.length) {
    console.log(`  today commits: ${snap.working_on.today_commits.length}`);
  }
  if (snap.working_on.week_commit_topics?.length) {
    console.log(`  week topics:   ${snap.working_on.week_commit_topics.join(', ')}`);
  }
}

// Insight — aggregate the enriched tick trace into metrics mirroring the
// intent file in data/hum-intent.md. Read-only; hum-review uses the
// same computations against its own window.
// Drift audit — compare outcome.sent=true in hum-runs.jsonl vs hum-feedback
// entries in the same window. They should be 1:1. Non-zero delta means the
// send+log plumbing is dropping rows (the 2026-04-11..15 regression this
// whole subsystem was hardened to prevent).
function cmdHumAudit(args) {
  let windowHours = 24;
  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--window' && args[i + 1]) {
      const m = args[++i].match(/^(\d+)([dh]?)$/);
      if (m) windowHours = parseInt(m[1], 10) * (m[2] === 'd' ? 24 : 1);
    }
  }
  const asJson = hasFlag(args, '--json');
  const cutoff = Date.now() - windowHours * 3600 * 1000;

  function parseJsonl(p) {
    try {
      return fs.readFileSync(p, 'utf8').split('\n').filter(Boolean).map((l) => {
        try { return JSON.parse(l); } catch { return null; }
      }).filter(Boolean);
    } catch (e) {
      if (e.code === 'ENOENT') return [];
      throw e;
    }
  }

  const runs = parseJsonl(HUM_RUNS);
  const feedback = parseJsonl(HUM_FEEDBK);

  // A run "sent" if outcome.sent === true (new schema) OR decision === 'PING'
  // with a ping_id (legacy schema, pre-2026-04-15 rewrite). Accept `ts` or
  // `ran_at` as the timestamp key, and normalize `decision` case — historical
  // rows have varied in both dimensions.
  const sentPings = runs.filter((r) => {
    const ts = Date.parse(r.ts || r.ran_at || '');
    if (!Number.isFinite(ts) || ts < cutoff) return false;
    const newSchema = r.outcome?.sent === true && r.outcome.ping_id;
    const legacy = String(r.decision || '').toUpperCase() === 'PING' && r.ping_id;
    return newSchema || legacy;
  }).map((r) => r.outcome?.ping_id || r.ping_id);

  const feedbackPings = feedback.filter((r) => {
    const ts = Date.parse(r.sent_at || '');
    return Number.isFinite(ts) && ts >= cutoff;
  }).map((r) => r.ping_id);

  const sentSet = new Set(sentPings);
  const feedbackSet = new Set(feedbackPings);
  const missingFeedback = [...sentSet].filter((id) => !feedbackSet.has(id));
  const orphanFeedback = [...feedbackSet].filter((id) => !sentSet.has(id));
  const drift = missingFeedback.length + orphanFeedback.length;

  const report = {
    window_hours: windowHours,
    cutoff_iso: new Date(cutoff).toISOString(),
    pings_sent_in_runs: sentPings.length,
    pings_logged_in_feedback: feedbackPings.length,
    missing_feedback_for_sent: missingFeedback,
    orphan_feedback_no_run: orphanFeedback,
    drift_count: drift,
    healthy: drift === 0,
  };

  if (asJson) {
    console.log(JSON.stringify(report, null, 2));
  } else {
    const mark = drift === 0 ? c.green('OK') : c.red('DRIFT');
    console.log(`${c.bold('hum audit')} (last ${windowHours}h) — ${mark}`);
    console.log(`  sent in runs:      ${report.pings_sent_in_runs}`);
    console.log(`  logged in feedback: ${report.pings_logged_in_feedback}`);
    if (missingFeedback.length) {
      console.log(c.red(`  missing feedback (${missingFeedback.length}):`));
      for (const id of missingFeedback) console.log(`    ${id}`);
    }
    if (orphanFeedback.length) {
      console.log(c.yellow(`  orphan feedback (${orphanFeedback.length}):`));
      for (const id of orphanFeedback) console.log(`    ${id}`);
    }
  }

  process.exit(drift === 0 ? 0 : 1);
}

function cmdHumInsight(args) {
  const fs = require('fs');
  let sinceDays = 7;
  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--since' && args[i + 1]) {
      const m = args[++i].match(/^(\d+)([dh]?)$/);
      if (m) sinceDays = parseInt(m[1], 10) * (m[2] === 'h' ? 1 / 24 : 1);
    }
  }
  const cutoff = Date.now() - sinceDays * 24 * 3600 * 1000;

  let runs = [], feedback = [], learnings = [];
  try {
    runs = fs.readFileSync(HUM_RUNS, 'utf8').trim().split('\n').filter(Boolean).map((l) => {
      try { return JSON.parse(l); } catch { return null; }
    }).filter(Boolean).filter((r) => new Date(r.ts).getTime() >= cutoff);
  } catch {}
  try {
    feedback = fs.readFileSync(HUM_FEEDBK, 'utf8').trim().split('\n').filter(Boolean).map((l) => {
      try { return JSON.parse(l); } catch { return null; }
    }).filter(Boolean).filter((r) => new Date(r.sent_at || r.ts || 0).getTime() >= cutoff);
  } catch {}
  try {
    learnings = fs.readFileSync(HUM_LEARNINGS, 'utf8').trim().split('\n').filter(Boolean).map((l) => {
      try { return JSON.parse(l); } catch { return null; }
    }).filter(Boolean).filter((r) => new Date(r.answered_at || 0).getTime() >= cutoff);
  } catch {}

  const total = runs.length;
  if (total === 0) {
    console.log(c.dim(`No tick traces in the last ${sinceDays}d.`));
    return;
  }
  const bucket = { silent: 0, info: 0, question: 0, error: 0 };
  const perTopicCandidates = {}, perTopicWins = {}, perTopicErrors = {};
  const scoreDist = [];
  let sent = 0, downgrades = 0, bashGated = 0; // bashGated approximated by "no candidates AND no sonnet call"
  let meetingSuppressed = 0;

  for (const r of runs) {
    const d = r.sonnet?.decision || 'error';
    bucket[d] = (bucket[d] || 0) + 1;
    if (r.outcome?.sent) sent++;
    if (r.outcome?.downgrade_reason) downgrades++;
    for (const c of (r.harvest?.candidates || [])) {
      perTopicCandidates[c.topic] = (perTopicCandidates[c.topic] || 0) + 1;
    }
    for (const e of (r.harvest?.errors || [])) {
      perTopicErrors[e.topic] = (perTopicErrors[e.topic] || 0) + 1;
    }
    if (r.sonnet?.based_on_topic) {
      perTopicWins[r.sonnet.based_on_topic] = (perTopicWins[r.sonnet.based_on_topic] || 0) + 1;
    }
    if (typeof r.sonnet?.score === 'number') scoreDist.push(r.sonnet.score);
  }

  const silentRate = bucket.silent / total;
  const reactedCount = feedback.filter((f) => f.reaction).length;
  const positive = feedback.filter((f) => ['helpful', 'more', '👍'].includes(f.reaction)).length;
  const negative = feedback.filter((f) => ['skip', 'snooze', '👎', '💤'].includes(f.reaction)).length;
  const responseRate = feedback.length ? reactedCount / feedback.length : 0;
  const positiveRate = (positive + negative) ? positive / (positive + negative) : 0;
  const answerRate = bucket.question ? learnings.length / bucket.question : 0;

  if (hasFlag(args, '--json')) {
    console.log(JSON.stringify({
      window_days: sinceDays,
      total, silent_rate: silentRate, bucket,
      info_sent: sent, downgrades,
      info_response_rate: responseRate, info_positive_rate: positiveRate,
      questions_asked: bucket.question, questions_answered: learnings.length, answer_rate: answerRate,
      per_topic_candidates: perTopicCandidates, per_topic_wins: perTopicWins, per_topic_errors: perTopicErrors,
    }, null, 2));
    return;
  }

  console.log(c.bold(`Hum insight — last ${sinceDays}d`) + '\n');
  console.log(`  ticks:           ${total}`);
  console.log(`  silent:          ${bucket.silent}  (${(silentRate * 100).toFixed(1)}%)  ${silentRate >= 0.85 ? c.green('✓ intent') : c.yellow('below 0.85')}`);
  console.log(`  info:            ${bucket.info} (sent ${sent}, downgraded ${downgrades})`);
  console.log(`  question:        ${bucket.question}  (answered ${learnings.length}, rate ${(answerRate * 100).toFixed(0)}%)  ${answerRate >= 0.4 ? c.green('✓ intent') : c.yellow('below 0.40')}`);
  if (bucket.error) console.log(`  ${c.red('error:          ' + bucket.error)}`);

  console.log('\n  ' + c.bold('Info reactions'));
  console.log(`    response rate:  ${(responseRate * 100).toFixed(0)}%  ${responseRate >= 0.30 ? c.green('✓') : c.yellow('below 0.30')}`);
  console.log(`    positive rate:  ${(positiveRate * 100).toFixed(0)}%  (${positive}👍 / ${negative}👎)  ${positiveRate >= 0.60 ? c.green('✓') : c.yellow('below 0.60')}`);

  console.log('\n  ' + c.bold('Per-topic hit rate (wins ÷ candidates)'));
  const topics = Object.keys(perTopicCandidates).sort();
  for (const t of topics) {
    const cand = perTopicCandidates[t] || 0;
    const wins = perTopicWins[t] || 0;
    const errs = perTopicErrors[t] || 0;
    const attempts = cand + errs;
    const hit = cand ? (wins / cand * 100).toFixed(0) + '%' : '—';
    const errRate = attempts ? (errs / attempts * 100).toFixed(0) + '%' : '0%';
    const errColor = errs / (attempts || 1) > 0.1 ? c.yellow : c.dim;
    console.log(`    ${t.padEnd(18)} cand=${String(cand).padStart(3)}  wins=${String(wins).padStart(3)} (${hit})  ${errColor('err=' + errs + ' (' + errRate + ')')}`);
  }

  if (scoreDist.length) {
    scoreDist.sort((a, b) => a - b);
    const med = scoreDist[Math.floor(scoreDist.length / 2)];
    const p90 = scoreDist[Math.floor(scoreDist.length * 0.9)];
    console.log('\n  ' + c.bold('Sonnet score distribution') + `  median=${med.toFixed(2)}  p90=${p90.toFixed(2)}  (threshold 0.55)`);
  }
}

// Infer the user's current activity state from existing signals. Reads
// phone-channel-cursor.json (last inbound) + user-timezone.json (local TZ),
// classifies as active / winding_down / sleeping / waking. Used by
// trigger-hum.sh as a soft gate and exposed here for ad-hoc inspection.
function inferActivityState() {
  const fs = require('fs');
  const dataDir = `${process.env.MERLIN_HOME || `${process.env.HOME}/Dev/merlin`}/data`;
  const readJson = (p) => { try { return JSON.parse(fs.readFileSync(p, 'utf8')); } catch { return null; } };
  const cursor = readJson(`${dataDir}/phone-channel-cursor.json`);
  const tzdata = readJson(`${dataDir}/user-timezone.json`);
  const tz = (tzdata && tzdata.timezone) || 'America/New_York';
  const lastSeenAt = cursor && cursor.lastSeenAt ? new Date(cursor.lastSeenAt) : null;
  const ageMin = lastSeenAt ? Math.round((Date.now() - lastSeenAt.getTime()) / 60000) : null;
  const localHour = parseInt(
    new Intl.DateTimeFormat('en-US', { timeZone: tz, hour: '2-digit', hour12: false }).format(new Date()),
    10
  );
  let state = 'active';
  let reason = `${localHour}:00 local, inbound ${ageMin ?? '?'}m ago`;
  if (localHour >= 1 && localHour < 7) {
    state = 'sleeping';
    reason = `sleep window ${localHour}:00 local`;
  } else if ((localHour >= 22 || localHour < 1) && (ageMin === null || ageMin >= 30)) {
    state = 'winding_down';
    reason = `late (${localHour}:00) + no phone activity ${ageMin ?? '?'}m`;
  } else if (localHour >= 7 && localHour < 9 && ageMin !== null && ageMin < 30) {
    state = 'waking';
    reason = `morning + fresh phone activity ${ageMin}m ago`;
  }
  return { state, last_inbound_min_ago: ageMin, local_hour: localHour, local_tz: tz, reason };
}

function cmdContext(args) {
  const ctxBuilder = require(path.join(TOOLS, 'lib/merlin-context.js'));
  const skipCache = hasFlag(args, '--fresh');
  const ctx = ctxBuilder.build({ skipCache });
  if (hasFlag(args, '--json')) { console.log(JSON.stringify(ctx, null, 2)); return; }
  console.log(c.bold('Merlin Context') + '\n');
  console.log(`  built_at: ${ctx.built_at}`);
  console.log(`\n  ${c.bold('Profile')}      ${Object.keys(ctx.profile).join(', ')}`);
  console.log(`  ${c.bold('Tastes')}       ${Object.keys(ctx.tastes).join(', ')}`);
  console.log(`  ${c.bold('Projects')}     ${Object.keys(ctx.projects).join(', ')}`);
  console.log(`\n  ${c.bold('Knowledge sources')} (${Object.keys(ctx.knowledge).length})`);
  for (const [k, v] of Object.entries(ctx.knowledge)) {
    console.log(`    ${k.padEnd(15)} ${c.dim(v.via)}`);
  }
  console.log(`\n  ${c.bold('Recent')}`);
  console.log(`    today commits:    ${ctx.recent.today_commits.length}`);
  console.log(`    today triage:     P1=${ctx.recent.today_triage.p1 || 0} P2=${ctx.recent.today_triage.p2 || 0} P3=${ctx.recent.today_triage.p3 || 0}`);
  console.log(`    hum runs 7d:      ${ctx.recent.counts.hum_runs_7d}`);
  console.log(`    hum feedback 14d: ${ctx.recent.counts.hum_feedback_14d}`);
  console.log(`    hum learnings 30d:${ctx.recent.counts.hum_learnings_30d}`);
  console.log(`    watchlist notify: ${ctx.recent.counts.watchlist_notify} shows`);
}

function cmdActivity(args) {
  const out = inferActivityState();
  if (hasFlag(args, '--state-only')) { console.log(out.state); return; }
  if (hasFlag(args, '--json')) { console.log(JSON.stringify(out)); return; }
  console.log(c.bold('Activity State') + '\n');
  console.log(`  state:     ${out.state}`);
  console.log(`  inbound:   ${out.last_inbound_min_ago ?? '—'} min ago`);
  console.log(`  local:     ${out.local_hour}:00 ${out.local_tz}`);
  console.log(`  reason:    ${out.reason}`);
}

// ========================================================================
// BOOTSTRAP / RUN-LOOP SUBCOMMANDS
// ========================================================================

function cmdInit(args) {
  // Interactive config wizard. Writes ROOT/.env (unless --force, asks before overwrite).
  // Generates a webhook-token. Creates required data/ subdirs.
  const readline = require('readline');
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  const ask = (q, def = '') => new Promise(r =>
    rl.question(`  ${q}${def ? c.dim(` [${def}]`) : ''}: `, ans => r(ans.trim() || def))
  );
  const envPath = path.join(ROOT, '.env');
  const force = hasFlag(args, '--force');

  (async () => {
    console.log(c.bold('Merlin init') + ' — interactive config\n');

    if (fs.existsSync(envPath) && !force) {
      const ans = await ask('.env already exists. Overwrite? (yes/no)', 'no');
      if (!/^y(es)?$/i.test(ans)) { console.log(c.dim('  aborted — .env left alone')); rl.close(); return; }
    }

    console.log(c.dim('  press Enter to accept defaults; leave fields blank for optional integrations\n'));

    const env = {};
    env.MERLIN_HOME = await ask('MERLIN_HOME (absolute path to this clone)', ROOT);

    console.log(c.bold('\n  Anthropic auth'));
    console.log(c.dim('  Mode 1: paste an API key  ·  Mode 2: leave blank and use `claude` login (Max subscription)'));
    env.ANTHROPIC_API_KEY = await ask('ANTHROPIC_API_KEY', '');

    console.log(c.bold('\n  Identity'));
    env.MERLIN_OWNER_EMAIL = await ask('Your primary email', '');
    env.MERLIN_OWNER = await ask('GitHub username / owner', '');

    console.log(c.bold('\n  Webhook channel'));
    const crypto = require('crypto');
    env.WEBHOOK_TOKEN = crypto.randomBytes(32).toString('hex');
    console.log(c.dim(`  generated WEBHOOK_TOKEN (random)`));

    console.log(c.bold('\n  Optional integrations') + c.dim(' (leave blank to skip; you can add later by editing .env)'));
    env.SUPABASE_URL = await ask('SUPABASE_URL', '');
    if (env.SUPABASE_URL) {
      env.SUPABASE_SERVICE_ROLE_KEY = await ask('SUPABASE_SERVICE_ROLE_KEY', '');
      env.MERLIN_SUPABASE_PROJECT = await ask('MERLIN_SUPABASE_PROJECT (project-ref)', '');
    }
    env.OLLAMA_URL = await ask('OLLAMA_URL', 'http://127.0.0.1:11434');
    env.LOCAL_LLM_MODEL = await ask('LOCAL_LLM_MODEL', 'gemma3:4b');
    env.LOCAL_EMBED_MODEL = await ask('LOCAL_EMBED_MODEL', 'nomic-embed-text');

    rl.close();

    const lines = [
      '# Merlin environment — generated by `merlin init`. Edit anytime.',
      `# Generated ${new Date().toISOString()}`,
      '',
      ...Object.entries(env).map(([k, v]) => `${k}=${v}`),
      '',
    ];
    fs.writeFileSync(envPath, lines.join('\n'));

    // Create runtime dirs
    for (const d of ['data', 'data/hum-cache', 'logs', 'agent/logs', 'agent/logs/supervisor-ops', 'agent/logs/supervisor-chat', 'agent/supervisor/state/ops', 'agent/supervisor/state/chat', 'secrets', 'credentials']) {
      fs.mkdirSync(path.join(ROOT, d), { recursive: true });
    }
    // Write the webhook token to the secrets dir (scripts read this directly)
    fs.writeFileSync(path.join(ROOT, 'secrets', 'webhook-token'), env.WEBHOOK_TOKEN + '\n');

    // Seed runtime config from examples/, but never overwrite existing files —
    // the user may have customized them between init runs.
    const seedMap = [
      ['examples/hum-interests.example.json', 'data/hum-interests.json'],
      ['examples/hum-intent.example.md',      'data/hum-intent.md'],
      ['examples/user-timezone.example.json', 'data/user-timezone.json'],
    ];
    const seeded = [];
    for (const [src, dst] of seedMap) {
      const dstAbs = path.join(ROOT, dst);
      if (fs.existsSync(dstAbs)) continue;
      const srcAbs = path.join(ROOT, src);
      if (!fs.existsSync(srcAbs)) continue;
      fs.copyFileSync(srcAbs, dstAbs);
      seeded.push(dst);
    }

    console.log(c.green('\n  ✓ .env written'));
    console.log(c.green('  ✓ data/, logs/, supervisor state/, secrets/ created'));
    console.log(c.green('  ✓ webhook-token written to secrets/webhook-token'));
    if (seeded.length) {
      console.log(c.green('  ✓ seeded ' + seeded.length + ' runtime config files from examples/:'));
      for (const s of seeded) console.log(c.dim('      ' + s));
    }
    console.log(c.dim('\nNext: ') + c.bold('./bin/merlin up'));
    console.log(c.dim('See docs/hum.md + docs/memory.md to populate the ambient-awareness loop + memory layer.'));
  })().catch(err => { console.error(c.red('Error: ') + err.message); process.exit(1); });
}

function cmdUp(args) {
  // Foreground mode: spawn process-manager as a child of this process,
  // forward signals so Ctrl-C cleanly tears down the whole tree.
  const pm = path.join(ROOT, 'agent/bin/process-manager.mjs');
  if (!fs.existsSync(pm)) die(`process-manager not found at ${pm}`);
  console.log(c.bold('Merlin up') + c.dim(' — Ctrl-C to stop'));
  console.log(c.dim(`  ROOT: ${ROOT}`));
  console.log();
  const child = spawn(process.execPath, [pm], { stdio: 'inherit', cwd: ROOT });
  for (const sig of ['SIGINT', 'SIGTERM', 'SIGHUP']) {
    process.on(sig, () => { try { child.kill(sig); } catch {} });
  }
  child.on('exit', (code, sig) => process.exit(code ?? (sig ? 128 : 0)));
}

function cmdDispatch(args) {
  // POST a job to the ops-supervisor webhook.
  //   merlin dispatch <job-name> [--task "task description"] [--port 9092]
  if (args.length === 0 || hasFlag(args, '-h', '--help')) {
    console.log('Usage: merlin dispatch <job-name> [--task "...task text..."] [--port <N>]');
    console.log('       merlin dispatch                   # list dispatch-able jobs');
    if (args.length === 0) {
      const tasks = loadTasks().filter(t => t.webhook_task);
      if (tasks.length) {
        console.log('\nDispatch-able jobs:');
        for (const t of tasks) console.log(`  ${t.name.padEnd(24)} ${c.dim(t.description?.slice(0, 60) || '')}`);
      }
    }
    return;
  }
  const jobName = args[0];
  const task = getFlag(args, '--task') || jobName.toUpperCase().replace(/-/g, ' ');
  const port = getFlag(args, '--port', '9092');
  // Resolve token from .env or secrets/webhook-token
  let token = process.env.WEBHOOK_TOKEN;
  if (!token) {
    try { token = fs.readFileSync(path.join(ROOT, 'secrets/webhook-token'), 'utf8').trim(); } catch {}
  }
  if (!token) {
    try {
      const env = fs.readFileSync(path.join(ROOT, '.env'), 'utf8');
      const m = env.match(/^WEBHOOK_TOKEN=(.+)$/m);
      if (m) token = m[1].trim();
    } catch {}
  }
  if (!token) die('No WEBHOOK_TOKEN — run `merlin init` first.');
  const payload = JSON.stringify({ task, source: 'merlin-cli', job: jobName });
  const cmd = `curl -s -o /dev/null -w '%{http_code}' -X POST http://localhost:${port} -H 'Authorization: Bearer ${token}' -H 'Content-Type: application/json' -d '${payload.replace(/'/g, "'\\''")}'`;
  try {
    const code = execSync(cmd, { encoding: 'utf8' }).trim();
    if (code.startsWith('2')) console.log(c.green('✓') + ` dispatched ${c.bold(jobName)} (HTTP ${code})`);
    else die(`dispatch failed: HTTP ${code}. Is the supervisor running? Try \`merlin up\`.`);
  } catch (e) { die(`dispatch failed: ${e.message}`); }
}

function cmdTail(args) {
  // Tail one of the well-known log streams.
  //   merlin tail              # ops supervisor events (default)
  //   merlin tail ops|chat     # supervisor stream
  //   merlin tail <job-name>   # logs/<job>.log
  //   merlin tail --all        # multiplex ops + chat
  const which = args[0] || 'ops';
  const all = hasFlag(args, '--all');
  const candidates = [];
  if (all || which === 'ops') candidates.push({ label: 'ops', path: path.join(AGENT_LOGS, 'supervisor-ops/events.ndjson') });
  if (all || which === 'chat') candidates.push({ label: 'chat', path: path.join(AGENT_LOGS, 'supervisor-chat/events.ndjson') });
  if (!all && which !== 'ops' && which !== 'chat') {
    // Treat as a job name → logs/<name>.log
    candidates.length = 0;
    candidates.push({ label: which, path: path.join(TOP_LOGS, `${which}.log`) });
  }
  const ok = candidates.filter(c => fs.existsSync(c.path));
  if (!ok.length) {
    console.log(c.dim('No log files yet — start the system with `merlin up` and try again.'));
    for (const c of candidates) console.log(c.dim(`  expected: ${c.path}`));
    return;
  }
  // Just shell out to `tail -F` for the best UX
  const tailArgs = ['-F'].concat(ok.map(c => c.path));
  const child = spawn('tail', tailArgs, { stdio: 'inherit' });
  for (const sig of ['SIGINT', 'SIGTERM']) process.on(sig, () => { try { child.kill(sig); } catch {} });
  child.on('exit', (code) => process.exit(code ?? 0));
}

// ========================================================================
// MAIN DISPATCH
// ========================================================================
const [, , cmd, ...args] = process.argv;
if (!cmd || cmd === 'help' || cmd === '--help' || cmd === '-h') { cmdHelp(); process.exit(0); }

const dispatch = {
  // Bootstrap / run-loop
  init: cmdInit,
  up: cmdUp,
  dispatch: cmdDispatch,
  tail: cmdTail,
  // Observability + task registry
  tasks: cmdTasks,
  status: cmdStatus,
  services: cmdServices,
  logs: cmdLogs,
  cron: cmdCron,
  git: cmdGit,
  ci: cmdCi,
  triage: cmdTriage,
  hum: cmdHum,
  restart: cmdRestart,
  arch: cmdArch,
  where: cmdWhere,
  doctor: cmdDoctor,
  cost: cmdCost,
  activity: cmdActivity,
  context: cmdContext,
};

const fn = dispatch[cmd];
if (!fn) { console.error(c.red(`unknown subcommand: ${cmd}`) + '\n'); cmdHelp(); process.exit(1); }
fn(args);
