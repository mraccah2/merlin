default_platform(:ios)

platform :ios do
  desc "Register App ID and enable capabilities"
  lane :setup_capabilities do
    produce(
      app_identifier: "com.example.Merlin",
      app_name: "Merlin",
      skip_itc: true,
      enable_services: {
        push_notification: "on",
        icloud: "cloudkit",
      }
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    json = JSON.parse(File.read("asc-api-key.json"))
    api_key = app_store_connect_api_key(
      key_id: json["key_id"],
      issuer_id: json["issuer_id"],
      key_content: json["key"],
      in_house: json["in_house"]
    )

    # Write the key to a temp .p8 file for xcodebuild auth
    key_path = File.join(Dir.tmpdir, "AuthKey_#{json["key_id"]}.p8")
    File.write(key_path, json["key"])

    new_build = latest_testflight_build_number(api_key: api_key) + 1
    increment_build_number(
      build_number: new_build,
      xcodeproj: "Merlin.xcodeproj"
    )

    build_app(
      scheme: "Merlin",
      export_method: "app-store",
      xcodebuild_formatter: "",
      export_options: {
        signingStyle: "automatic",
        teamID: "TEAMID_PLACEHOLDER"
      },
      xcargs: "-allowProvisioningUpdates -authenticationKeyPath '#{key_path}' -authenticationKeyID '#{json["key_id"]}' -authenticationKeyIssuerID '#{json["issuer_id"]}'"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      ipa: lane_context[SharedValues::IPA_OUTPUT_PATH]
    )
  end
end
