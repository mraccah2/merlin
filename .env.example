# Merlin environment — copy to `.env` (which is gitignored) and fill in.
# `merlin init` will scaffold this for you; this template documents every
# variable Merlin's components look for.

# ─── Required: where Merlin lives on disk ────────────────────────────────
# Most scripts derive paths from MERLIN_HOME. Set this to the absolute path
# of your clone (no trailing slash). Defaults to $HOME/Dev/merlin.
MERLIN_HOME=

# ─── Anthropic auth (pick ONE) ───────────────────────────────────────────
# Mode 1: API key. Easiest to set up. Pay-per-token.
ANTHROPIC_API_KEY=

# Mode 2: Claude Max subscription.
# Leave ANTHROPIC_API_KEY unset. Authenticate `claude` once interactively
# on this host (`claude` → browser flow), and the supervisor will spawn
# claude -p children with the Max session. See agent/supervisor/claude-session.mjs
# for the env-scrubbing pattern.

# ─── Webhook channel auth ────────────────────────────────────────────────
# Token that cron-driven scripts present when POSTing /dispatch.
# `merlin init` generates a random 32-byte hex value.
WEBHOOK_TOKEN=

# ─── Optional integrations ───────────────────────────────────────────────

# Supabase (used by phone-channel + companion-app + APNs push pipeline)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=        # for the supabase-mcp server (Management API)
MERLIN_SUPABASE_PROJECT=      # project-ref (the slug in <ref>.supabase.co)

# Google Cloud (Gmail Pub/Sub push)
MERLIN_GCP_PROJECT=
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=

# Firebase RTDB (heartbeat)
MERLIN_FIREBASE_PROJECT=

# Hookdeck (Gmail Pub/Sub tunnel)
MERLIN_HOOKDECK_URL=

# Identity strings (used in outbound email / messages)
MERLIN_OWNER=                 # your GitHub login (used in repo URLs)
MERLIN_OWNER_EMAIL=           # the user's primary email
MERLIN_AGENT_FROM_EMAIL=      # the From: address agent-originated email uses
MERLIN_DOMAIN=                # your domain for outbound (e.g. example.com)
MERLIN_HOST=                  # hostname (used in launchd labels)

# Outbound mail (SMTP2Go)
SMTP2GO_API_KEY=

# Local LLM (Ollama)
OLLAMA_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=gemma3:4b
LOCAL_EMBED_MODEL=nomic-embed-text

# Memory backup (optional — auto-snapshot the memory dir to a private repo)
MERLIN_BACKUP_REPO=

# Override paths (mostly for tests; defaults compute from MERLIN_HOME)
# MEMORY_INDEX_DB=
# MEMORY_INDEX_DIR=
# MEMORY_INDEX_LOG=

# ─── Telemetry ───────────────────────────────────────────────────────────
# Set by `merlin init` based on your Y/n answer. Values: on | off.
# Controls one anonymous first-run install ping — no PII, no raw IP. See
# apps/telemetry/README.md for the exact payload.
MERLIN_TELEMETRY=on

# Hard kill-switch — if set to 1 in the process env, no ping is sent
# regardless of MERLIN_TELEMETRY. Useful for ephemeral CI installs.
# MERLIN_NO_TELEMETRY=1

# Override the telemetry endpoint (e.g. if you forked and re-deployed
# apps/telemetry/ under your own Vercel project).
# MERLIN_TELEMETRY_URL=https://merlin-telemetry.vercel.app/install

# Token authorizing `merlin-cost-report --push` to send per-day Claude
# usage/cost rollups to the hosted /usage endpoint (and to read /stats and
# /usage). PRIVATE operator telemetry — unlike the install ping this is NOT
# anonymous adoption data, so the endpoint refuses it without this token.
# Leave unset on public clones. Value lives in 1Password (Dev vault →
# "Merlin Telemetry Upstash KV" → STATS_TOKEN); falls back to STATS_TOKEN.
# MERLIN_USAGE_TOKEN=
